# Track these files
*
.DS_Store
!setup.sh
!README.md
!CLAUDE.md
!.gitignore
!.gitattributes
!starship.toml
!.pre-commit-config.yaml

# Track everything in these directories
!bin/
!bin/**
!zed/
!zed/**
!zsh/
!zsh/**
!micro/
!micro/**
!setup/
!setup/**
!ghostty/
!ghostty/**
!.claude/
!.claude/**
!vivaldi/
!vivaldi/**
!aerospace/
!aerospace/**
!linearmouse/
!linearmouse/**
!graphify-out/
# Track only the queryable graph (union-merged via .gitattributes). The rest of
# graphify-out/ is machine-specific (.graphify_python/.graphify_root hold
# absolute paths) or regenerable locally by the git hook (graph.html,
# GRAPH_REPORT.md), so it stays ignored.
!graphify-out/graph.json

# Ignore these specific directories
.DS_Store
**/.DS_Store
.claude/scheduled_tasks.lock
zed/prompts/
zsh/.zshrc.zwc
zsh/.zcompdump
zsh/.zsh_history
zsh/.zsh_sessions/
micro/backups/
micro/buffers/

# Machine-local / secret-bearing — must never be tracked (re-ignored despite !.claude/**)
.claude/settings.local.json
fish/fish_variables
