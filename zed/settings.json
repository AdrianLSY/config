{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
      "default_mode": "bypassPermissions",
    },
  },
  "terminal": {
    "dock": "right",
  },
  "icon_theme": "Material Icon Theme",
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_profile": "write",
    "play_sound_when_agent_done": true,
    "always_allow_tool_actions": true,
    "model_parameters": [],
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5-latest",
    },
  },
  "ui_font_size": 14,
  "buffer_font_size": 12,
  "buffer_font_family": "Noto Sans Mono",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Max",
  },
  "autosave": "on_focus_change",
  "languages": {
    "Python": {
      "language_servers": ["basedpyright"],
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "basedpyright": {
          "typeCheckingMode": "strict",
        },
      },
    },
  },
}
